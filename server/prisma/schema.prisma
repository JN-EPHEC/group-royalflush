generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  /// Pseudo affiché en jeu (obligatoire à l’inscription ; nullable pour anciennes lignes)
  username       String?         @unique
  password       String
  balance        Float           @default(1000)
  createdAt      DateTime        @default(now())

  blackjackGames BlackjackGame[]
  rouletteGames  RouletteGame[]
  transactions   Transaction[]
  refreshTokens  RefreshToken[]
}

model BlackjackGame {
  id          Int      @id @default(autoincrement())
  userId      Int
  betAmount   Float
  playerScore Int
  dealerScore Int
  result      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RouletteGame {
  id            Int      @id @default(autoincrement())
  userId        Int
  betType       String
  betValue      String
  betAmount     Float
  winningNumber Int
  result        String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            Int      @id @default(autoincrement())
  userId        Int
  amount        Float
  type          String
  balanceBefore Float
  balanceAfter  Float
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}