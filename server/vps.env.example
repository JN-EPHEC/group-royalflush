# Exemple pour le VPS — copie ce fichier sur le serveur puis renomme / édite.
# Sur le VPS : nano ~/royalflush-api.env  (colle le contenu et remplace les valeurs)
#
# Règles pour --env-file Docker :
# - une variable par ligne, format CLE=valeur
# - pas de guillemets " autour des valeurs (sauf si tu maîtrises l’échappement)
# - pas d’espace avant/après le =

DATABASE_URL=postgresql://USER:MOTDEPASSE@HOST:5432/postgres?sslmode=require
JWT_SECRET=remplace_par_une_longue_chaine_aleatoire_sans_espaces
ADMIN_SETUP_KEY=remplace_par_une_cle_admin_secrete
